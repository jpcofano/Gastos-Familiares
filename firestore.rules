rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function authDoc()    { return get(/databases/$(database)/documents/autorizados/$(request.auth.token.email.lower())); }
    function esAdmin() {
      let d = authDoc();
      return isSignedIn() && request.auth.token.email_verified == true && d != null && d.data.rol == 'admin';
    }
    function esMiembro() {
      let d = authDoc();
      return isSignedIn() && request.auth.token.email_verified == true && d != null && d.data.memberId != null;
    }
    function miMemberId() {
      let d = authDoc();
      return d != null ? d.data.memberId : null;
    }

    // config/familia: legible por cualquier signed-in (necesario para bootstrap)
    match /config/{doc} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // Catálogos de solo lectura — solo miembros resueltos
    match /tcDiario/{id} {
      allow read:  if esMiembro();
      allow write: if false;
    }
    match /subcategorias/{id} {
      allow read:  if esMiembro();
      allow write: if false;
    }
    match /etiquetas/{id} {
      allow read:  if esMiembro();
      allow write: if false;
    }

    // Whitelist de acceso — sembrado, inmutable desde el cliente
    match /autorizados/{email} {
      allow read:  if isSignedIn() && request.auth.token.email_verified == true;
      allow write: if false;
    }

    // Movimientos — lectura scoped, create validado campo a campo, update/delete cerrado
    match /movimientos/{id} {
      allow read: if esAdmin() || (esMiembro() && resource.data.persona == miMemberId());
      allow create: if esMiembro()
        && request.resource.data.creadoPor == miMemberId()
        && (esAdmin() || request.resource.data.persona == miMemberId())
        && request.resource.data.tipo in ['Gasto', 'Ingreso']
        && request.resource.data.moneda in ['ARS', 'USD']
        && request.resource.data.monto is number
        && request.resource.data.monto > 0
        && request.resource.data.fecha is timestamp
        && request.resource.data.mes is string
        && request.resource.data.mes.matches('^[0-9]{4}-[0-9]{2}$')
        && request.resource.data.creadoEn == request.time
        && request.resource.data.actualizadoEn == request.time
        && request.resource.data.descripcion is string
        && request.resource.data.descripcion.size() > 0;
      allow update: if esAdmin()
        && request.resource.data.creadoPor == resource.data.creadoPor
        && request.resource.data.creadoEn == resource.data.creadoEn
        && request.resource.data.actualizadoEn == request.time;
      allow delete: if false;
    }

    // Solo admins
    match /resumenesTarjeta/{id} {
      allow read, write: if esAdmin();
    }
    match /itemsEsperados/{id} {
      allow read: if esMiembro();
      allow create, update: if esAdmin()
        && request.resource.data.tipo in ['Gasto', 'Ingreso']
        && request.resource.data.moneda in ['ARS', 'USD']
        && request.resource.data.activo is bool
        && request.resource.data.periodicidad in ['mensual', 'bimestral', 'trimestral', 'anual', 'unico']
        && request.resource.data.pagoAutomatico is bool;
      allow delete: if esAdmin();
    }
    match /reglasNormalizacion/{id} {
      allow read:  if esMiembro();
      allow write: if false;
    }

    // Comprobantes — subida por cualquier miembro, update/delete solo admin
    match /comprobantes/{hash} {
      allow read:   if esMiembro();
      allow create: if esMiembro();
      allow update, delete: if esAdmin();
    }

    // Entrantes — punto de entrada único para subida de archivos
    match /entrantes/{hash} {
      allow read:   if esMiembro() && (esAdmin() || resource.data.creadoPor == miMemberId());
      allow create: if esMiembro()
        && request.resource.data.creadoPor == miMemberId()
        && request.resource.data.estado == 'pendiente'
        && request.resource.data.hash is string;
      allow update, delete: if false;   // solo el router (admin SDK) escribe estado/destino
    }

    // Diccionario — lectura por todos los miembros (clasificador client-side); escritura admin + manual
    match /diccionario/{id} {
      allow read: if esMiembro();
      allow create, update: if esAdmin() || (esMiembro() && request.resource.data.origen == 'Manual');
      allow delete: if esAdmin();
    }
  }
}
