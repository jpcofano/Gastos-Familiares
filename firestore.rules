rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function authDoc()    { return get(/databases/$(database)/documents/autorizados/$(request.auth.uid)); }
    function esAdmin() {
      let d = authDoc();
      return isSignedIn() && d != null && d.data.rol == 'admin';
    }
    function esMiembro() {
      let d = authDoc();
      return isSignedIn() && d != null && d.data.memberId != null;
    }
    function miMemberId() {
      let d = authDoc();
      return d != null ? d.data.memberId : null;
    }

    // config/familia: legible por cualquier signed-in (necesario para bootstrap:
    // useMiembro lo lee ANTES de escribir autorizados/{uid})
    match /config/{doc} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // Catálogos de solo lectura — solo miembros resueltos
    match /tcDiario/{id} {
      allow read:  if esMiembro();
      allow write: if false;
    }
    match /subcategorias/{id} {
      allow read:  if esMiembro();
      allow write: if false;
    }
    match /etiquetas/{id} {
      allow read:  if esMiembro();
      allow write: if false;
    }

    // Doc propio del usuario (escrito por el cliente al resolver memberId)
    match /autorizados/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Movimientos — lectura scoped, create validado campo a campo, update/delete cerrado
    match /movimientos/{id} {
      allow read: if esAdmin() || (esMiembro() && resource.data.persona == miMemberId());
      allow create: if esMiembro()
        && request.resource.data.creadoPor == miMemberId()
        && (esAdmin() || request.resource.data.persona == miMemberId())
        && request.resource.data.tipo in ['Gasto', 'Ingreso']
        && request.resource.data.moneda in ['ARS', 'USD']
        && request.resource.data.monto is number
        && request.resource.data.monto > 0
        && request.resource.data.fecha is timestamp
        && request.resource.data.mes is string
        && request.resource.data.mes.matches('^[0-9]{4}-[0-9]{2}$')
        && request.resource.data.creadoEn == request.time
        && request.resource.data.actualizadoEn == request.time
        && request.resource.data.descripcion is string
        && request.resource.data.descripcion.size() > 0;
      allow update, delete: if false;
    }

    // Solo admins
    match /resumenesTarjeta/{id} {
      allow read, write: if esAdmin();
    }
    match /itemsEsperados/{id} {
      allow read, write: if esAdmin();
    }
    match /reglasNormalizacion/{id} {
      allow read:  if esAdmin();
      allow write: if false;
    }

    // Diccionario — lectura admin + escritura manual por cualquier miembro
    match /diccionario/{id} {
      allow read: if esAdmin();
      allow create, update: if esAdmin() || (esMiembro() && request.resource.data.origen == 'Manual');
      allow delete: if esAdmin();
    }
  }
}
