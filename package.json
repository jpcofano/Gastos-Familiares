{
  "name": "gastos-familiares",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema familiar de gestion de gastos sobre Firebase",
  "scripts": {
    "seed": "tsx scripts/seed/seed.ts --target=emulator",
    "seed:prod": "tsx scripts/seed/seed.ts --target=production",
    "seed:dry": "tsx scripts/seed/seed.ts --target=emulator --dry-run",
    "validate": "tsx scripts/seed/validators/runValidations.ts",
    "emulators": "firebase emulators:start --only auth,firestore --import=./emulator-data --export-on-exit",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "emu": "firebase emulators:start --only auth,firestore,functions,storage --import=./emulator-data --export-on-exit=./emulator-data"
  },
  "dependencies": {
    "firebase": "^10.12.0",
    "lucide-react": "^1.21.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "firebase-admin": "^12.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "xlsx": "^0.18.5"
  }
}
